# LightSpace Webshell — environment variables
# Copy to .env and fill in your values. Only LIGHTARCHITECTS_WEBSHELL_TOKEN is required.

# ── Required ──────────────────────────────────────────────────────────────────

# Auth token for the webshell HTTP API and SSE streams.
# Generate with: openssl rand -hex 32
LIGHTARCHITECTS_WEBSHELL_TOKEN=

# ── LLM backend (choose one) ──────────────────────────────────────────────────

# Option A: Ollama (local or cloud)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=glm-5.1:cloud

# Option B: Anthropic Claude (via Claude Code CLI or direct API key)
# ANTHROPIC_API_KEY=sk-ant-...

# Option C: LiteLLM proxy (OpenAI-compatible — covers Gemini, Bedrock, etc.)
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_STUB_PREFIX=stub-la-

# ── Optional services ─────────────────────────────────────────────────────────

# Hermes MCP bridge (enables additional MCP tool routing)
# HERMES_MCP_URL=http://localhost:7890
# HERMES_MCP_ENABLED=true

# Override the default storage root (~/.lightarchitects)
# LIGHTARCHITECTS_HOME=/path/to/custom/dir

# Logging level: error | warn | info | debug | trace
# RUST_LOG=info
