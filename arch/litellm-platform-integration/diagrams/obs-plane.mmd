    end

    subgraph "Providers"
        ANT[Anthropic]
        OAI[OpenAI]
        OLL[Ollama local]
        OLC[Ollama Cloud]
        DSK[DeepSeek]
        VTX[Vertex AI]
        MST[Mistral]
    end

    subgraph "macOS Keychain"
        KC["/usr/bin/security<br/>la-*-credential"]
    end

    WS -->|"LitellmConfig.build_provider()"| LLMProv
    LLMProv -->|"POST /v1/chat/completions<br/>+ W3C traceparent"| LPROXY
