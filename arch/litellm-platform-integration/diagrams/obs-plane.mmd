graph LR
    subgraph "LA Webshell (port 8733)"
        WS[Copilot Turn Handler<br/>copilot/mod.rs]
        LLMProv[LitellmProvider<br/>litellm_state.rs]
        SSE[SSE Stream<br/>litellm_chat.rs]
        AYIN_TS[ayin_traces_utils.ts<br/>turn_span_id mint]
    end

    subgraph "LiteLLM Proxy (:4000)"
        LPROXY[litellm proxy<br/>litellm_config.yaml]
