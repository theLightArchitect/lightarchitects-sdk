    LKSP -->|"security CLI subprocess"| KC
    LPROXY -->|"startup secret resolution"| LKSP

    LPROXY --> ANT
    LPROXY --> OAI
    LPROXY --> OLL
    LPROXY --> OLC
    LPROXY --> DSK
    LPROXY --> VTX
    LPROXY --> MST

    OTELcb -->|"gRPC OTLP"| OTELCOL
