# LiteLLM environment variables — copy to .env and fill in real values.
# NEVER commit .env — it contains live credentials.
#
# Setup order:
#   1. Regenerate your Portkey API key at app.portkey.ai → Settings → API Keys
#   2. Create Anthropic virtual key at app.portkey.ai → Virtual Keys → + New
#   3. Store both in macOS Keychain:
#        security add-generic-password -a la-portkey -s portkey-api-key -w pk-...
#        security add-generic-password -a la-portkey -s portkey-vk-anthropic -w pv-...
#   4. Write this .env from keychain:
#        echo "PORTKEY_API_KEY=$(security find-generic-password -a la-portkey -s portkey-api-key -w)" >> .env
#        echo "PORTKEY_VIRTUAL_KEY_ANTHROPIC=$(security find-generic-password -a la-portkey -s portkey-vk-anthropic -w)" >> .env

# ── Portkey (replaces raw Anthropic key) ──────────────────────────────────────
# Account API key — authenticates requests to Portkey's gateway.
PORTKEY_API_KEY=pk-...

# Virtual key for Anthropic — encrypted credential stored in Portkey's vault.
# Create at: app.portkey.ai → Virtual Keys → + New → Select Anthropic → paste API key
PORTKEY_VIRTUAL_KEY_ANTHROPIC=pv-...

# ── OpenRouter — direct (Phase 2: migrate to Portkey virtual key) ─────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── RunPod — direct (Phase 2: Portkey custom-host virtual key) ────────────────
RUNPOD_API_KEY=...

# ── LiteLLM internal ──────────────────────────────────────────────────────────
# Master key for LiteLLM's own API authentication (used by gateway via LA_LITELLM_API_KEY).
LITELLM_MASTER_KEY=sk-litellm-...

# Postgres (LiteLLM usage tracking DB — internal to docker-compose).
DATABASE_URL=postgresql://litellm:litellm_dev@postgres:5432/litellm
POSTGRES_PASSWORD=litellm_dev
