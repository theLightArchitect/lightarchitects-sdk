# LiteLLM vault sidecar — copy to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.

# LiteLLM master key — used by webshell to authenticate virtual key operations.
# Generate: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-la-change-me

# PostgreSQL password for the litellm database.
POSTGRES_PASSWORD=litellm_dev

# DATABASE_URL constructed from postgres service name in docker-compose.yml.
DATABASE_URL=postgresql://litellm:${POSTGRES_PASSWORD}@postgres:5432/litellm

# Provider API keys — exactly ONE of these is needed per provider you route through.
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
RUNPOD_API_KEY=...

# Optional: Vertex AI (requires GCP credentials file or ADC)
# VERTEX_PROJECT=my-gcp-project
